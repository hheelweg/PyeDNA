force evaluation via 1 MD step
&cntrl
  imin      = 0,     ! MD mode (CRITICAL)
  ntx       = 1,
  irest     = 0,

  nstlim    = 1,     ! exactly ONE step
  dt        = 0.0,   ! no propagation

  ntb       = 1,
  ntp       = 0,

  ntc       = 1,
  ntf       = 1,

  ntpr      = 1,
  ntwx      = 0,
  ntwf      = 1,     

  ioutfm    = 1,
  cut       = 8.0,
/